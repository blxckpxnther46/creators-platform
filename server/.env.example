# ============================================
# Server Environment Variables - TEMPLATE
# Copy this to .env and fill in your actual values
# DO NOT COMMIT .env TO GIT (contains secrets)
# ============================================

# Application Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ============================================
# MongoDB Connection
# - Local development: mongodb://localhost:27017/creators-platform
# - Docker Compose: mongodb://mongo:27017/creators-platform
# - MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname
# ============================================
MONGODB_URI=mongodb://localhost:27017/creators-platform

# ============================================
# JWT Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ============================================
# Cloudinary Configuration
# Get credentials from https://cloudinary.com/console
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_key:your_secret@your_cloud_name
