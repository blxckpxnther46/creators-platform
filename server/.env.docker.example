# ============================================
# Server Environment Variables - DOCKER OVERRIDE TEMPLATE
# Copy this to .env.docker and fill in Docker-specific values
# DO NOT COMMIT .env.docker TO GIT (if it contains secrets)
# ============================================

# ============================================
# MongoDB Connection for Docker Compose
# Override: Uses 'mongo' service name for Docker network DNS resolution
# 
# Local .env value:   mongodb://localhost:27017/creators-platform
# Docker .env.docker: mongodb://mongo:27017/creators-platform
#
# 'mongo' is the service name in docker-compose.yml
# Docker's embedded DNS resolves 'mongo' to the container's IP
# ============================================
MONGODB_URI=mongodb://mongo:27017/creators-platform

# Override NODE_ENV for Docker production deployment
NODE_ENV=production

# Optional: override PORT if Docker deployment uses different port
# PORT=5000

# Optional: Add any other Docker-specific environment variables
# For example, if using different storage paths in Docker:
# LOG_DIR=/app/logs
