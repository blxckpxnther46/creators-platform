# Files and directories to exclude from Docker build context
# These reduce build time and image size

# Dependencies - will be installed in the container
node_modules
npm-debug.log
yarn-error.log
npm-error.log

# Environment files - secrets, use build args instead
.env
.env.local
.env.*.local

# Git
.git
.gitignore
.gitattributes

# Build outputs - will be rebuilt in the container
dist
build

# Development tools
.vscode
.idea
.DS_Store
*.swp
*.swo
*~
.editorconfig
.prettierrc
.eslintrc*

# IDE
.vscode
.idea
*.sublime-project
*.sublime-workspace

# Documentation
README.md
CHANGELOG.md

# Testing
__tests__
__mocks__
coverage
.nyc_output

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Docker files
Dockerfile
docker-compose.yml
.dockerignore
DOCKER_*

# Package manager cache
.npm
.yarn
