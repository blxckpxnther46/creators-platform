# Docker Environment Variables
# Copy this file to .env.docker and fill in your actual values
# Used only when running with Docker/docker-compose

# Node Environment
NODE_ENV=production
PORT=5000

# MongoDB Connection
# For docker-compose, use the service name: mongo
MONGODB_URI=mongodb://mongo:27017/creators-platform

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cloudinary Configuration
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: MongoDB Credentials (if using authentication)
# MONGO_USER=admin
# MONGO_PASSWORD=your_secure_password

# Logging
LOG_LEVEL=info
